# Rename to secrets.toml for LOCAL runs, OR paste these into
# Streamlit Community Cloud: App -> Settings -> Secrets.
# Streamlit loads these into os.environ, which is what the app reads.
# Only needed for the "Refresh data" (Alpaca) button. The explorer works without them.
paper_alpaca_key = "YOUR_ALPACA_PAPER_KEY"
paper_alpaca_secret = "YOUR_ALPACA_PAPER_SECRET"
