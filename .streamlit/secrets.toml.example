# Paste these into Streamlit Cloud: Manage app -> Settings -> Secrets.
# Streamlit loads them into os.environ / st.secrets.

# --- Permanent "Refresh + retrain" button (dispatches the GitHub Action) ---
# A GitHub token with Actions: Read and write on this repo.
GH_TOKEN = "github_pat_XXXXXXXXXXXXXXXXXXXX"
GH_REPO  = "redxia/feature-explorer"
# GH_WORKFLOW = "daily-update.yml"   # defaults to this
# GH_BRANCH   = "main"               # defaults to this

# --- Optional: only needed if you ever use the old in-app Alpaca fetch ---
# paper_alpaca_key = "YOUR_ALPACA_PAPER_KEY"
# paper_alpaca_secret = "YOUR_ALPACA_PAPER_SECRET"
